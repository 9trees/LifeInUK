"use strict";$(document).ready(function(){if("undefined"!=typeof DATA){var a=JSON.parse(DATA);if("undefined"!=typeof a.maintenance_warning&&a.maintenance_warning){var b=parseInt(localStorage.getItem("maintenance_warn"),10),c=Date.now();if("undefined"==typeof b||!b||b<c){var d;d="undefined"!=typeof a.maintenance_warning_period&&a.maintenance_warning_period?" between "+a.maintenance_warning_period:"";var e="We&rsquo;ll be carrying out essential maintenance"+d+".<br />We regret that the site won&rsquo;t be accessible ";e+=d?"during this period.":"at this time.";var g,f='<a class="accept" href="#">Got it</a>';g="undefined"!=typeof a.maintenance_warning_link&&a.maintenance_warning_link?'View <a href="'+a.maintenance_warning_link+'">more information</a>':"";var h='<div class="maintenance-info"><div class="outerWrapper"><div class="wrapper"><div class="single"><div>'+e+f+"<br />"+g+"</div></div></div></div></div>";$("body").prepend(h),$(".maintenance-info a.accept").on("click",function(b){b.preventDefault(),$(".maintenance-info a.accept").off("click"),$(".maintenance-info").slideUp(200,function(){if($(".maintenance-info").detach(),"undefined"!=typeof a.maintenance_warning_repeat&&a.maintenance_warning_repeat){var b=Date.now()+60*a.maintenance_warning_repeat*60*1e3;localStorage.setItem("maintenance_warn",b)}})})}}}});